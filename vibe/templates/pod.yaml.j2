apiVersion: v1
kind: Pod
metadata:
  name: {{ project_name }}-vibe
  labels:
    app: {{ project_name }}-vibe
    vibe.secure/deployed: "true"
spec:
  securityContext:
    seLinuxOptions:
      type: container_t
  initContainers:
{% if pip_packages %}
    - name: pip-install
      image: registry.access.redhat.com/ubi9/python-39
      command:
        - /bin/bash
        - -c
        - pip3 install --target /packages {{ pip_packages | join(' ') }}
      volumeMounts:
        - name: pip-packages
          mountPath: /packages
{% endif %}
    - name: code-extract
      image: registry.access.redhat.com/ubi9/python-39
      command:
        - /bin/bash
        - -c
        - tar -xzf /archive/vibe-code.tar.gz -C /app
      volumeMounts:
        - name: vibe-archive
          mountPath: /archive
          readOnly: true
        - name: app-code
          mountPath: /app
  containers:
    - name: vibe-runner
      image: registry.access.redhat.com/ubi9/python-39
      command: ["python3", "/app/{{ entry_point }}"]
{% if pip_packages or '/' in entry_point %}
      env:
        - name: PYTHONPATH
          value: "{{ '/app:/packages' if pip_packages and '/' in entry_point else '/packages' if pip_packages else '/app' }}"
{% endif %}
      volumeMounts:
{% if pip_packages %}
        - name: pip-packages
          mountPath: /packages
          readOnly: true
{% endif %}
{% if use_spire %}
        - name: spiffe-workload-api
          mountPath: /run/spire/sockets
          readOnly: true
{% endif %}
        - name: app-code
          mountPath: /app
          readOnly: true
  volumes:
{% if pip_packages %}
    - name: pip-packages
      emptyDir: {}
{% endif %}
    - name: vibe-archive
      configMap:
        name: {{ project_name }}-vibe-code
    - name: app-code
      emptyDir: {}
{% if use_spire %}
    - name: spiffe-workload-api
      csi:
        driver: csi.spiffe.io
        readOnly: true
        volumeAttributes:
          spiffeID: spiffe://example.org/workload/{{ project_name }}
{% endif %}
